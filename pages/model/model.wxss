.model-page {
  padding-bottom: 48rpx;
}

.model-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.model-header > view {
  flex: 1;
}

.explain-toggle {
  flex: none;
  min-width: 152rpx;
  padding: 18rpx 18rpx;
  border-radius: 999rpx;
  background: #e9f3ef;
  color: #1f6d5e;
  font-size: 23rpx;
  font-weight: 750;
}

.canvas-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
  padding: 14rpx;
  background: #ffffff;
}

.model-canvas {
  display: block;
  border-radius: 12rpx;
  overflow: hidden;
}

.season-tabs {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.season-btn {
  flex: 1;
  min-height: 116rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(55, 109, 164, 0.12);
  background: #ffffff;
  text-align: left;
}

.season-btn text {
  display: block;
}

.season-btn text:first-child {
  color: #18374d;
  font-size: 29rpx;
  font-weight: 850;
}

.season-btn text:last-child {
  margin-top: 10rpx;
  color: #637987;
  font-size: 23rpx;
}

.season-btn.active {
  border-color: #1f7a68;
  box-shadow: 0 14rpx 30rpx rgba(31, 122, 104, 0.14);
}

.season-btn.winter.active {
  background: #edf6fb;
}

.season-btn.summer.active {
  background: #fff3e8;
}

.switch-panel {
  margin-top: 22rpx;
  padding: 10rpx 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 108rpx;
  border-bottom: 1rpx solid rgba(38, 77, 96, 0.08);
}

.switch-row:last-child {
  border-bottom: 0;
}

.switch-row.disabled {
  opacity: 0.58;
}

.switch-row.disabled .switch-title,
.switch-row.disabled .switch-desc {
  color: #8a98a1;
}

.switch-row > view {
  flex: 1;
}

.switch-title,
.switch-desc {
  display: block;
}

.switch-title {
  color: #18374d;
  font-size: 27rpx;
  font-weight: 750;
}

.switch-desc {
  margin-top: 8rpx;
  color: #73838e;
  font-size: 22rpx;
}

.explain-card,
.state-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.explain-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feature-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f1f7f4;
  color: #1f6d5e;
  font-size: 23rpx;
  font-weight: 750;
}

.logic-list {
  margin-top: 18rpx;
}

.logic-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  margin-top: 14rpx;
  color: #415968;
  font-size: 25rpx;
  line-height: 1.55;
}

.logic-dot {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #1f7a68;
}

.state-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.state-grid view {
  box-sizing: border-box;
  width: calc(50% - 7rpx);
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f5f8f8;
}

.state-grid text {
  display: block;
}

.state-grid text:first-child {
  color: #74848e;
  font-size: 21rpx;
}

.state-grid text:last-child {
  margin-top: 8rpx;
  color: #18374d;
  font-size: 25rpx;
  font-weight: 780;
}

.impact-grid {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.impact-card {
  flex: 1;
  padding: 24rpx;
}

.impact-card text {
  display: block;
}

.impact-card text:first-child {
  color: #1f6d5e;
  font-size: 26rpx;
  font-weight: 820;
}

.impact-card text:last-child {
  margin-top: 12rpx;
  color: #5f7180;
  font-size: 23rpx;
  line-height: 1.55;
}
