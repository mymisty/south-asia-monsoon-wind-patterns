.compare-page {
  padding-bottom: 48rpx;
}

.compare-table {
  overflow: hidden;
  margin-top: 28rpx;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid rgba(39, 83, 101, 0.1);
}

.table-row:last-child {
  border-bottom: 0;
}

.table-row text {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 18rpx 14rpx;
  color: #314d5d;
  font-size: 23rpx;
  line-height: 1.35;
}

.table-row text:first-child {
  width: 22%;
  background: #f4f8f8;
  color: #17364b;
  font-weight: 780;
}

.table-row text:nth-child(2),
.table-row text:nth-child(3) {
  width: 39%;
}

.table-row text:nth-child(2) {
  background: rgba(232, 245, 251, 0.64);
}

.table-row text:nth-child(3) {
  background: rgba(255, 246, 235, 0.72);
}

.table-head text {
  min-height: 76rpx;
  background: #244e62 !important;
  color: #ffffff !important;
  font-weight: 850;
}

.summary-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.summary-text {
  display: block;
  margin-top: 18rpx;
  color: #4b6070;
  font-size: 26rpx;
  line-height: 1.65;
}
