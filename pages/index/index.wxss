.index-page {
  padding-bottom: 44rpx;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 82vh;
  border-radius: 0;
}

.hero-map {
  position: relative;
  overflow: hidden;
  height: 58vh;
  min-height: 620rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #e8f8fb 0%, #d1eef3 52%, #bfe1ea 100%);
  box-shadow: inset 0 -30rpx 80rpx rgba(29, 97, 123, 0.08);
}

.ocean,
.land,
.ridge,
.wind-line,
.rain-zone {
  position: absolute;
}

.ocean-left {
  left: -20%;
  top: 42%;
  width: 58%;
  height: 48%;
  border-radius: 50%;
  background: rgba(90, 176, 201, 0.22);
}

.ocean-right {
  right: -24%;
  top: 43%;
  width: 62%;
  height: 54%;
  border-radius: 50%;
  background: rgba(74, 163, 194, 0.2);
}

.mainland {
  left: 16%;
  top: 7%;
  width: 72%;
  height: 36%;
  border-radius: 36% 44% 20% 16%;
  background: #e7d8ba;
  transform: rotate(-4deg);
}

.peninsula {
  left: 39%;
  top: 30%;
  width: 28%;
  height: 38%;
  border-radius: 42% 36% 52% 54%;
  background: #e2cda8;
  transform: rotate(10deg);
}

.ridge-one,
.ridge-two {
  height: 18rpx;
  border-radius: 999rpx;
  background: #9a8a7a;
  box-shadow: 0 10rpx 0 rgba(255, 255, 255, 0.46);
}

.ridge-one {
  left: 32%;
  top: 24%;
  width: 40%;
  transform: rotate(-6deg);
}

.ridge-two {
  left: 39%;
  top: 28%;
  width: 34%;
  transform: rotate(7deg);
}

.wind-line {
  width: 190rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #e77442;
}

.wind-line::after {
  content: "";
  position: absolute;
  right: -18rpx;
  top: -14rpx;
  border-left: 32rpx solid #e77442;
  border-top: 23rpx solid transparent;
  border-bottom: 23rpx solid transparent;
}

.wind-a {
  left: 16%;
  top: 66%;
  transform: rotate(-38deg);
}

.wind-b {
  left: 48%;
  top: 70%;
  transform: rotate(-44deg);
}

.rain-zone {
  left: 55%;
  top: 34%;
  width: 34%;
  height: 30%;
  border-radius: 50%;
  background: rgba(35, 129, 196, 0.22);
  filter: blur(2rpx);
}

.map-note {
  position: absolute;
  color: rgba(26, 55, 70, 0.72);
  font-size: 22rpx;
  font-weight: 700;
}

.note-himalaya {
  left: 42%;
  top: 18%;
}

.note-ocean {
  left: 43%;
  bottom: 12%;
}

.hero-content {
  position: relative;
  margin-top: -148rpx;
  padding: 0 16rpx;
}

.eyebrow,
.hero-title,
.hero-subtitle {
  display: block;
}

.eyebrow {
  color: #1f7a68;
  font-size: 24rpx;
  font-weight: 750;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 900;
  color: #102f44;
}

.hero-subtitle {
  max-width: 680rpx;
  margin-top: 22rpx;
  color: #526b77;
  font-size: 28rpx;
  line-height: 1.65;
}

.hero .pill-row {
  margin-top: 26rpx;
}

.hero-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.hero-actions button {
  flex: 1;
}

.flow {
  margin-top: 34rpx;
  padding: 28rpx;
}

.flow-chain {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.flow-chain text {
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  background: #f2f7f5;
  color: #31515f;
  font-size: 24rpx;
  font-weight: 650;
}
