page {
  min-height: 100%;
  background: #f4f7fb;
  color: #182d3d;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  line-height: 1.2;
  font-size: 30rpx;
}

button::after {
  border: 0;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #153348;
  letter-spacing: 0;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #5f7180;
  font-size: 26rpx;
  line-height: 1.6;
}

.card {
  box-sizing: border-box;
  border: 1rpx solid rgba(37, 91, 118, 0.12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 45rpx rgba(31, 76, 98, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 750;
  color: #17364b;
}

.primary-btn,
.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 12rpx;
  font-weight: 750;
}

.primary-btn {
  background: #1f7a68;
  color: #ffffff;
  box-shadow: 0 14rpx 26rpx rgba(31, 122, 104, 0.22);
}

.secondary-btn {
  border: 1rpx solid rgba(31, 122, 104, 0.25);
  background: #ffffff;
  color: #1f6d5e;
}

.nav-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.nav-actions button {
  flex: 1;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 122, 104, 0.1);
  color: #1e675c;
  font-size: 23rpx;
  font-weight: 650;
}

.muted {
  color: #6d7d88;
}
